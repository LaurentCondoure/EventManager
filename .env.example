# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit it.

# SQL Server SA password (used by Docker to initialise the container).
# Must meet SQL Server complexity requirements:
# uppercase, lowercase, digit, special character, minimum 8 characters.
SA_PASSWORD=

# Application user password (eventmanagement_user).
# Must match the password in your user secrets connection string.
APP_PASSWORD=
